# Per-host .env template for multi-host deployment. Copy to .env and fill per machine.
# Used by docker-compose.node.yml. The real .env is git-ignored.

# ── Same across the whole cluster (identical on every machine) ──
# 32-byte hex: od -vN 32 -An -tx1 /dev/urandom | tr -d ' \n'
CLUSTER_SECRET=

# Replication factor: -1 = pin on every node (full redundancy).
# With more nodes, set concrete numbers to save space, e.g. RF_MIN=2 / RF_MAX=3.
RF_MIN=-1
RF_MAX=-1

# ── Different per machine ──────────────────────────────────────
# Node name (unique within the cluster), e.g. node-a / node-b / node-c
NODE_NAME=node-a

# This host's address reachable by other peers (private IP in one VPC; public IP across clouds)
ANNOUNCE_IP=10.0.0.11

# Host data-disk path (ECS data disk); ipfs/ and cluster/ are created under it
DATA_DIR=/data/ipfs-cluster

# Bind address for the proxy port (9095, Agent upload): 127.0.0.1 = local only.
# If the Agent runs elsewhere, set a reachable address and restrict via security group.
PROXY_BIND=127.0.0.1

# ── Seed machine only ──────────────────────────────────────────
# IS_SEED=true

# ── Non-seed machines only (values come from the seed after startup, see docs/MULTI_HOST_DEPLOYMENT.md §3) ──
# IPFS_SEED_ADDR=/ip4/10.0.0.11/tcp/4001/p2p/<seed kubo PeerID>
# CLUSTER_PEERADDRESSES=/ip4/10.0.0.11/tcp/9096/p2p/<seed cluster PeerID>

# ── Optional: NAT only (container cannot infer its external address) ──
# CLUSTER_ANNOUNCE=/ip4/<this host external IP>/tcp/9096
