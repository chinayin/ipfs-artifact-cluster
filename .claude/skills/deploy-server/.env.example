# deploy-server 技能配置模板（脱敏占位）
#
# 用法：
#   cp .env.example .env    # 在 .claude/skills/deploy-server/ 下
#   然后填好下面的值再跑 deploy.sh
#
# 配置解析优先级：进程环境变量为主 → 本文件（.env）兜底。
#   即：已在 shell/CI 里 export 的同名变量优先，未设置的才从 .env 读。
#
# 连接方式（自动识别，优先用 key）：
#   1) 显式设置 DEPLOY_SSH_KEY  → 用该私钥（-i）
#   2) 未设 key，但默认 key / ssh-agent 能免密登录 → 直接用（BatchMode 探测）
#   3) 以上都不行，且设了 DEPLOY_SSH_PASSWORD → 用 sshpass 密码兜底
#   4) 全都没有 → 报错
#   推荐用 key；密码仅兜底，能不用就留空。
#
# 安全：
#   本文件（.claude/skills/**/.env）已被 .gitignore 兜底忽略，绝不会进 git。
#   请勿把真实密码/私钥路径提交到仓库。

# 服务器 IP 或域名（必填）
DEPLOY_SSH_HOST=

# 登录用户（默认 root）
DEPLOY_SSH_USER=root

# SSH 端口（默认 22）
DEPLOY_SSH_PORT=22

# 远端部署目录（默认 /data/ipfs）
# 注意：这是生产上手工维护的文件子集，不是 git 仓库。
DEPLOY_REMOTE_DIR=/data/ipfs

# 私钥路径（可选，优先）。设置后强制用该 key 登录，例如 /Users/you/.ssh/id_ed25519
# 用 key 时下面的密码请留空。
DEPLOY_SSH_KEY=

# 密码（可选，兜底）。仅当没有可用 key 时才使用；用 key 就留空。
# 需要密码登录时开发机须装 sshpass（brew install sshpass）。
DEPLOY_SSH_PASSWORD=

# 对外读域名 / 基址，供部署后只读渲染验证用，例如 https://pages.example.com
# 留空则跳过域名渲染验证（其余验证照常）。
IPFS_BASE_URL=
