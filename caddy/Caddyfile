# 读取站点（对外）：友好路径 /artifact/<CID> 重写为 /ipfs/<CID>，轮询三网关做 LB。
# 站点地址由 SITE_DOMAIN 决定（compose 注入）：
#   - 未设 → 默认 :80（本地 HTTP，配合 HTTP_PORT 映射到宿主）；
#   - 设为域名(如 pages.example.com) → Caddy 自动签发/续期 Let's Encrypt 证书并强制 HTTPS。
# 域名模式前提：DNS 解析到本机公网 IP + 宿主开放 80/443。详见 docs/SINGLE_HOST_DEPLOYMENT.md「域名与公网 HTTPS」。
{$SITE_DOMAIN} {
	# /artifact/<CID>[/...] → /ipfs/<CID>[/...]
	@art path /artifact/*
	uri @art replace /artifact/ /ipfs/

	reverse_proxy ipfs0:8080 ipfs1:8080 ipfs2:8080 {
		lb_policy round_robin
	}
}

# 上传写入口：token 鉴权，只放行 POST /add，反代到 cluster0 REST :9094。
# 供 Agent 发布技能调用；:9094/:9095/:5001 原生端口仍不暴露。详见 docs/SINGLE_HOST_DEPLOYMENT.md。
:9097 {
	route {
		# 1) 校验 Bearer token（值由 compose 注入的 IPFS_PUBLISH_TOKEN 提供）
		@unauth not header Authorization "Bearer {$IPFS_PUBLISH_TOKEN}"
		respond @unauth "Unauthorized" 401

		# 2) 只放行 /add，堵死其余 REST 管理路由（unpin / peers 等）
		# 只放行 POST /add：非 POST 方法 或 非 /add 路径 一律 403
		@notpost not method POST
		respond @notpost "Forbidden" 403
		@notadd not path /add
		respond @notadd "Forbidden" 403

		reverse_proxy cluster0:9094
	}
}
